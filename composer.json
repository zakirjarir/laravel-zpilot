{
    "name": "zakirjarir/laravel-installer",
    "description": "An ultra-modern, intelligent, and secure web-based installation wizard for Laravel applications with a premium glassmorphism UI.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Zakir Jarir",
            "email": "zakirjarir@gmail.com",
            "homepage": "https://github.com/zakirjarir",
            "role": "Developer"
        }
    ],
    "keywords": [
        "laravel",
        "installer",
        "setup",
        "wizard",
        "gui",
        "environment",
        "database"
    ],
    "require": {
        "php": "^7.4|^8.0",
        "laravel/framework": "^8.0|^9.0|^10.0|^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "ZakirJarir\\LaravelInstaller\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "ZakirJarir\\LaravelInstaller\\InstallerServiceProvider"
            ]
        }
    }
}